<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/scrollLog"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#000000"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <!-- Title -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Lat OS"
            android:textSize="42sp"
            android:textColor="#FFFFFF"
            android:textStyle="bold"
            android:layout_gravity="center_horizontal"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Hands-Free Voice Control"
            android:textSize="14sp"
            android:textColor="#00BCD4"
            android:layout_gravity="center_horizontal"
            android:layout_marginBottom="16dp"/>

        <!-- Status -->
        <TextView
            android:id="@+id/tvStatus"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Starting..."
            android:textSize="14sp"
            android:textColor="#FF4444"
            android:layout_marginBottom="12dp"/>

        <!-- Permissions -->
        <Button
            android:id="@+id/btnGrantPermissions"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="PERMISSIONS &amp; SETTINGS"
            android:textSize="14sp"
            android:padding="14dp"
            android:layout_marginBottom="8dp"/>

        <!-- Start/Stop -->
        <Button
            android:id="@+id/btnStartListening"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="START VOICE CONTROL"
            android:textSize="14sp"
            android:padding="14dp"
            android:backgroundTint="#4CAF50"
            android:layout_marginBottom="8dp"/>

        <Button
            android:id="@+id/btnStopListening"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="STOP VOICE CONTROL"
            android:textSize="14sp"
            android:padding="14dp"
            android:backgroundTint="#F44336"
            android:visibility="gone"
            android:layout_marginBottom="8dp"/>

        <!-- Scan Apps -->
        <Button
            android:id="@+id/btnScanApps"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="SCAN ALL INSTALLED APPS"
            android:textSize="14sp"
            android:padding="14dp"
            android:backgroundTint="#2196F3"
            android:layout_marginBottom="16dp"/>

        <!-- Test Command -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Test Command"
            android:textSize="16sp"
            android:textColor="#4CAF50"
            android:textStyle="bold"/>

        <EditText
            android:id="@+id/etCommand"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="e.g. open youtube"
            android:textColor="#FFFFFF"
            android:textColorHint="#666666"
            android:background="#222222"
            android:padding="12dp"
            android:textSize="14sp"
            android:inputType="text"
            android:imeOptions="actionSend"
            android:layout_marginBottom="8dp"/>

        <Button
            android:id="@+id/btnSendCommand"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="RUN TEST COMMAND"
            android:textSize="14sp"
            android:padding="14dp"
            android:backgroundTint="#9C27B0"
            android:layout_marginBottom="16dp"/>

        <!-- Test Finder -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Test App Finder"
            android:textSize="16sp"
            android:textColor="#4CAF50"
            android:textStyle="bold"/>

        <EditText
            android:id="@+id/etTestApp"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="e.g. youtube"
            android:textColor="#FFFFFF"
            android:textColorHint="#666666"
            android:background="#222222"
            android:padding="12dp"
            android:textSize="14sp"
            android:inputType="text"
            android:layout_marginBottom="8dp"/>

        <Button
            android:id="@+id/btnTestFinder"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="FIND THIS APP"
            android:textSize="14sp"
            android:padding="14dp"
            android:backgroundTint="#009688"
            android:layout_marginBottom="16dp"/>

        <!-- Log Output -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Log Output"
            android:textSize="16sp"
            android:textColor="#FFFFFF"
            android:textStyle="bold"
            android:layout_marginBottom="4dp"/>

        <TextView
            android:id="@+id/tvLog"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:minHeight="200dp"
            android:background="#111111"
            android:padding="8dp"
            android:textSize="11sp"
            android:textColor="#00FF00"
            android:fontFamily="monospace"
            android:text=""/>

        <Button
            android:id="@+id/btnClearLog"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="CLEAR LOG"
            android:textSize="12sp"
            android:padding="10dp"
            android:layout_marginTop="8dp"/>

    </LinearLayout>
</ScrollView>
